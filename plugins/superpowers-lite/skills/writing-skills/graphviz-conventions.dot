digraph STYLE_GUIDE {
    // Process-diagram style guide written in its own DSL.
    rankdir=TB;

    subgraph cluster_node_types {
        label="节点类型与形状";

        "这是问题吗？" [shape=diamond];
        "执行动作" [shape=box];
        "git status" [shape=plaintext];
        "当前状态" [shape=ellipse];
        "停止：高风险操作" [shape=octagon, style=filled, fillcolor=red, fontcolor=white];
        "流程开始" [shape=doublecircle];
        "流程完成" [shape=doublecircle];
    }

    subgraph cluster_edges {
        label="边标签";

        "二元判断？" [shape=diamond];
        "是路径" [shape=box];
        "否路径" [shape=box];
        "二元判断？" -> "是路径" [label="是"];
        "二元判断？" -> "否路径" [label="否"];

        "多项选择？" [shape=diamond];
        "选项甲" [shape=box];
        "选项乙" [shape=box];
        "默认选项" [shape=box];
        "多项选择？" -> "选项甲" [label="条件甲"];
        "多项选择？" -> "选项乙" [label="条件乙"];
        "多项选择？" -> "默认选项" [label="其他"];
    }

    subgraph cluster_structure {
        label="流程结构模板";

        "触发：发生事件" [shape=ellipse];
        "满足前置条件？" [shape=diamond];
        "执行主要动作" [shape=box];
        "npm test" [shape=plaintext];
        "证据通过？" [shape=diamond];
        "执行替代动作" [shape=box];
        "停止：不得继续" [shape=octagon, style=filled, fillcolor=red, fontcolor=white];
        "交付完成" [shape=doublecircle];

        "触发：发生事件" -> "满足前置条件？";
        "满足前置条件？" -> "执行主要动作" [label="是"];
        "满足前置条件？" -> "执行替代动作" [label="否"];
        "执行主要动作" -> "npm test";
        "npm test" -> "证据通过？";
        "证据通过？" -> "交付完成" [label="通过"];
        "证据通过？" -> "停止：不得继续" [label="失败"];
        "执行替代动作" -> "交付完成";
    }

    subgraph cluster_shape_rules {
        label="形状选择";

        "选择节点形状" [shape=ellipse];
        "它是决策？" [shape=diamond];
        "使用菱形" [shape=diamond, style=filled, fillcolor=lightblue];
        "它是命令？" [shape=diamond];
        "使用纯文本" [shape=plaintext];
        "它是警告？" [shape=diamond];
        "使用八边形" [shape=octagon, style=filled, fillcolor=pink];
        "它是入口或出口？" [shape=diamond];
        "使用双圆" [shape=doublecircle, style=filled, fillcolor=lightgreen];
        "它是状态？" [shape=diamond];
        "使用椭圆" [shape=ellipse, style=filled, fillcolor=lightyellow];
        "默认使用方框" [shape=box, style=filled, fillcolor=lightcyan];

        "选择节点形状" -> "它是决策？";
        "它是决策？" -> "使用菱形" [label="是"];
        "它是决策？" -> "它是命令？" [label="否"];
        "它是命令？" -> "使用纯文本" [label="是"];
        "它是命令？" -> "它是警告？" [label="否"];
        "它是警告？" -> "使用八边形" [label="是"];
        "它是警告？" -> "它是入口或出口？" [label="否"];
        "它是入口或出口？" -> "使用双圆" [label="是"];
        "它是入口或出口？" -> "它是状态？" [label="否"];
        "它是状态？" -> "使用椭圆" [label="是"];
        "它是状态？" -> "默认使用方框" [label="否"];
    }
}

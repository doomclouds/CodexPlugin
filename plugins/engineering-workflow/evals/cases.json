{
  "schema_version": 2,
  "cases": [
    {
      "id": "small-clear-change",
      "prompt": "把 README 里的错别字‘验正’改成‘验证’，改完确认没有其他改动。",
      "expected_skills": ["build", "verify"],
      "allowed_skills": ["build", "verify"],
      "order_constraints": [["build", "verify"]],
      "required_patterns": {
        "acceptance_criteria": ["README", "验证|改动"]
      }
    },
    {
      "id": "material-product-ambiguity",
      "prompt": "给账户管理增加删除功能。软删除还是彻底删除会影响合规和恢复能力，请先把这个决定澄清，暂时不要写代码。",
      "expected_skills": ["clarify"],
      "allowed_skills": ["clarify"]
    },
    {
      "id": "cross-session-feature",
      "prompt": "为采集服务实现断线重连：最多重试 3 次、指数退避、取消立即停止、耗尽后返回明确失败。任务会跨多个会话，请完成规格、计划、实现、审查和验收。",
      "expected_skills": ["plan", "tdd", "review", "verify"],
      "allowed_skills": ["clarify", "plan", "tdd", "review", "verify"],
      "order_constraints": [["plan", "tdd"], ["tdd", "review"], ["review", "verify"]],
      "required_patterns": {
        "acceptance_criteria": ["取消", "重试|重连"],
        "edge_behaviors": ["取消"]
      }
    },
    {
      "id": "diagnosis-only",
      "prompt": "只诊断为什么服务在每天零点偶发 CPU 飙升，给出复现证据和根因；不要修改任何文件。",
      "expected_skills": ["debug"],
      "allowed_skills": ["debug"]
    },
    {
      "id": "fix-reproducible-bug",
      "prompt": "定位并修复 CSV 最后一行没有换行时被漏读的问题，补回归测试，审查并验收。",
      "expected_skills": ["debug", "tdd", "review", "verify"],
      "allowed_skills": ["debug", "tdd", "review", "verify"],
      "order_constraints": [["debug", "tdd"], ["tdd", "review"], ["review", "verify"]],
      "required_patterns": {
        "goal": ["CSV"],
        "acceptance_criteria": ["换行|EOF|最后"]
      }
    },
    {
      "id": "external-current-fact",
      "prompt": "调研当前 .NET SDK 是否原生支持生成 OpenAPI 3.1，只查官方一手资料并给结论，不要改代码。",
      "expected_skills": ["explore"],
      "allowed_skills": ["explore"]
    },
    {
      "id": "review-only",
      "prompt": "只审查当前 diff 是否满足需求、工程质量以及安全可靠性，列出可操作问题，不要修复。",
      "expected_skills": ["review"],
      "allowed_skills": ["review"]
    },
    {
      "id": "verify-only",
      "prompt": "只验收当前实现是否满足现有验收条件，运行必要命令并给证据；失败就报告，不要改代码。",
      "expected_skills": ["verify"],
      "allowed_skills": ["verify"]
    },
    {
      "id": "whole-group-does-not-mean-all-skills",
      "prompt": "使用整个工程协作技能组，把命令行帮助里的一个 typo 修掉并验证，不要扩大范围。",
      "expected_skills": ["build", "verify"],
      "allowed_skills": ["build", "verify"],
      "order_constraints": [["build", "verify"]]
    },
    {
      "id": "domain-language-update",
      "prompt": "我们代码里把同一个业务概念同时叫 Record、Acquisition 和 Capture。请统一领域语言，更新对应领域的 CONTEXT.md 和 CONTEXT.MAP.md 导航，不要修改实现。",
      "expected_skills": ["clarify"],
      "allowed_skills": ["clarify"],
      "required_patterns": {
        "goal": ["领域|术语|Record|Acquisition|Capture"]
      }
    },
    {
      "id": "architecture-design-only",
      "prompt": "只设计采集设备模块的公共接口和公开测试入口，比较至少两个方案，不要开始实现。",
      "expected_skills": ["plan"],
      "allowed_skills": ["plan"],
      "required_patterns": {
        "acceptance_criteria": ["公共接口", "方案"]
      }
    },
    {
      "id": "persist-complex-task",
      "prompt": "这项设备断线重连工作会跨多个会话。先统一 ConnectionAttempt、ReconnectPolicy 等领域术语，再把规格和可恢复计划写入仓库；本次不要实现。",
      "expected_skills": ["clarify", "plan"],
      "allowed_skills": ["clarify", "plan"],
      "order_constraints": [["clarify", "plan"]],
      "required_patterns": {
        "goal": ["ConnectionAttempt|ReconnectPolicy|领域.{0,8}术语"]
      }
    },
    {
      "id": "pause-and-handoff",
      "prompt": "这个复杂任务还没做完，我准备换一个新会话。请把当前进度、工作区、验证和下一步保存下来，别继续实现。",
      "expected_skills": ["plan"],
      "allowed_skills": ["plan"],
      "required_patterns": {
        "goal": ["进度|恢复|新会话|下一步"]
      }
    },
    {
      "id": "explicit-tdd-core-rule",
      "prompt": "使用 TDD 为计费模块增加阶梯折扣规则：前 100 件原价，超过部分九折。请实现并验收，不要引入新的测试框架。",
      "expected_skills": ["tdd", "verify"],
      "allowed_skills": ["tdd", "verify"],
      "order_constraints": [["tdd", "verify"]],
      "required_patterns": {
        "acceptance_criteria": ["100", "九折|折扣|90%"],
        "action_boundary": ["RED", "GREEN"]
      }
    },
    {
      "id": "generated-code-no-tdd",
      "prompt": "重新生成 OpenAPI 客户端后更新生成文件中的版本常量，并运行现有生成校验。不要手写测试生成代码。",
      "expected_skills": ["build", "verify"],
      "allowed_skills": ["build", "verify"],
      "order_constraints": [["build", "verify"]]
    },
    {
      "id": "throwaway-prototype-only",
      "prompt": "纸面上无法判断设备重连状态机是否可行。做一个一次性终端原型比较两个状态模型，记录结论，不要修改生产实现。",
      "expected_skills": ["explore"],
      "allowed_skills": ["explore"],
      "required_patterns": {
        "goal": ["原型|状态模型|状态机"]
      }
    },
    {
      "id": "research-then-plan",
      "prompt": "先查当前厂商 SDK 的官方线程模型，再据此制定跨会话接入计划；本次不要实现。",
      "expected_skills": ["explore", "plan"],
      "allowed_skills": ["clarify", "explore", "plan"],
      "order_constraints": [["explore", "plan"]],
      "required_patterns": {
        "goal": ["SDK|线程|计划"]
      }
    },
    {
      "id": "review-fix-verify",
      "prompt": "审查当前 diff，修复确认存在的可操作问题，然后运行验收；不要顺手重构无关代码。",
      "expected_skills": ["review", "verify"],
      "allowed_skills": ["review", "build", "tdd", "verify"],
      "required_one_of": [["build", "tdd"]],
      "order_constraints": [
        ["review", "build"],
        ["review", "tdd"],
        ["build", "verify"],
        ["tdd", "verify"]
      ]
    },
    {
      "id": "failed-verification-no-fix",
      "prompt": "运行现有验收并报告失败证据。即使测试失败也不要修复或修改文件。",
      "expected_skills": ["verify"],
      "allowed_skills": ["verify"]
    },
    {
      "id": "hardware-log-no-fake-tdd",
      "prompt": "给真实采集卡断连回调增加一条诊断日志。当前没有硬件，不要为了 TDD 伪造设备模型；完成能做的验证并明确未运行项。",
      "expected_skills": ["build", "verify"],
      "allowed_skills": ["build", "verify"],
      "order_constraints": [["build", "verify"]],
      "required_patterns": {
        "risks": ["硬件|设备|环境|采集卡"]
      }
    }
  ]
}
